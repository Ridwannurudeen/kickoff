# --- Optional tuning (sensible defaults if unset) ---
# lib/gen-markets.mjs (full World Cup coverage generator)
# MATCH_LIMIT: how many matches get per-match (1X2/OU2.5/BTTS) markets. 0 = all 104.
MATCH_LIMIT=8
# MATCH_MARKETS: which per-match markets to emit (comma-sep of 1x2,ou25,btts).
