# Kickoff off-chain scripts — copy to .env and fill in. NEVER commit .env.
# Rename this file:  cp env-example .env   (it is named env-example because a
# pre-commit hook blocks writing dotfiles named .env*; the content is the template.)
# Private keys are read from here at runtime and never logged.

# --- Network (env-driven; never hardcode the testnet id) ---
# X Layer mainnet: CHAIN_ID=196, RPC_URL=https://rpc.xlayer.tech
# X Layer testnet: CHAIN_ID is ambiguous (195 vs 1952) — set whatever your RPC reports.
RPC_URL=https://rpc.xlayer.tech
