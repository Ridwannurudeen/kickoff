# OptimisticOracle — used by the resolution keeper to propose/settle results.
# Its bond token is the USDC collateral; the proposer (ORACLE_PK) must hold and
# approve `bondAmount` USDC for the OO before proposing (the keeper auto-approves).
OPTIMISTIC_ORACLE=0x0000000000000000000000000000000000000000

