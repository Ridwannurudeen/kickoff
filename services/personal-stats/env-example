# personal-stats — copy to .env and fill in. NEVER commit .env.
# Named `env-example` because a pre-commit hook blocks writing dotfiles
# matching `.env*`; the content is the template. To use:
#     cp env-example .env

# --- Network ---
RPC_URL=https://testrpc.xlayer.tech/terigon
CHAIN_ID=1952

# --- Deployed addresses on X Layer ---
AGENT_REGISTRY=
# FanRep contract — read by this service to compute the caller's score().
FAN_REP=

# --- This agent's id + wallet ---
# AGENT_ID = keccak256("kickoff.personal-stats.v1")
AGENT_ID=
# AGENT_PK: PLACEHOLDER NAME ONLY — never put a real key in this file.
AGENT_PK=

# --- LLM provider (optional — this service can run pure-deterministic) ---
LLM_API_KEY=
LLM_MODEL=claude-3-5-haiku-latest

# --- Demo mode ---
OFFLINE_MODE=
